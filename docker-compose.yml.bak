
version: '3.9'
services:
  db:
    image: postgres:15
    environment:
      POSTGRES_PASSWORD: postgres
      POSTGRES_DB: todo
    ports: ["5432:5432"]
  backend:
    build: ./backend
    env_file: ./backend/.env.example
    depends_on: [db]
    ports: ["3001:3000"]
  frontend:
    image: node:20-alpine
    working_dir: /app
    volumes: ["./frontend:/app"]
    command: sh -c "npm install && npm run dev -- --host"
    ports: ["5173:5173"]
